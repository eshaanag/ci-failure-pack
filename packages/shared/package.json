{
  "name": "@ci-failure-pack/shared",
  "version": "0.1.0",
  "description": "Shared types, schemas, parsers, and reproduction logic for CI Failure Pack.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cosmiconfig": "^9.0.0",
    "fast-xml-parser": "^5.2.3",
    "yaml": "^2.8.0",
    "zod": "^3.25.0"
  }
}
